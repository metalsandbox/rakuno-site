---
const links = [
  { label: '首页', href: '/' },
  { label: '项目', href: '/projects' },
  { label: '博客', href: '/blog' },
  { label: '艺术', href: '/art' },
];
---

<nav class="nav">
  <div class="nav-inner container">
    <a href="/" class="nav-logo">楽</a>
    <ul class="nav-links">
      {links.map(link => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 21, 39, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }

  .nav-logo {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-accent);
    font-family: var(--font-display);
  }

  .nav-links {
    display: flex;
    gap: var(--space-lg);
  }

  .nav-links a {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
    transition: color var(--transition-fast);
  }

  .nav-links a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 480px) {
    .nav-links {
      gap: var(--space-md);
    }
    .nav-links a {
      font-size: 0.8rem;
    }
  }
</style>
