<section class="hero">
  <div class="container hero-inner">
    <p class="hero-kanji">楽</p>
    <h1 class="hero-name">raku</h1>
    <p class="hero-tagline">创造有趣的事物</p>
  </div>
</section>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }

  .hero-kanji {
    font-size: 1.2rem;
    color: var(--color-text-muted);
    font-family: var(--font-display);
    letter-spacing: 0.2em;
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(5rem, 16vw, 10rem);
    font-weight: 400;
    color: var(--color-accent);
    line-height: 1;
    letter-spacing: 0.05em;
  }

  .hero-tagline {
    margin-top: var(--space-sm);
    font-size: 1rem;
    color: var(--color-text-muted);
    letter-spacing: 0.08em;
  }
</style>
